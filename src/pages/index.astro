---
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Contact from "../components/Contact.astro";
import Tools from "../components/Tools.astro";
import PageLoader from "../components/PageLoader.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <script>
      import { pageLoadAnimation } from "../utils/animations";

      addEventListener("load", () => {
        pageLoadAnimation();
      });
    </script>
  </head>
  <body
    class="bg-linear-to-br from-brand-orange-light to-brand-sand-dark"
  >
    <PageLoader />
    <div
      class="min-h-screen flex items-center justify-center overflow-clip p-0 md:p-8 xl:p-12 2xl:px-56"
    >
      <div
        id="content"
        class="flex my-auto mx-auto w-[90%] md:w-[650px] p-8 md:p-16 2xl:max-h-[950px] z-50 shadow-xl bg-brand-sand-light rounded-2xl overflow-clip"
      >
        <div class="flex flex-col justify-between gap-8 w-full">
          <div class="flex flex-col gap-4 md:gap-8">
            <h1 id="title" class="text-3xl md:text-5xl font-light">
              Juan Abbona
            </h1>

            <p id="about" class="text-sm md:text-base">
              Software engineer based in Montevideo, Uruguay.
              <br />
              <br />With over 10 years of experience, I specialize in building
              modern web applications. On the frontend I work primarily with
              React and TypeScript; on the backend I've delivered solutions
              using Python, Node.js and C#.
              <br />
              <br />I'm also deeply interested in UI/UX design, and I care
              about crafting interfaces that are both visually refined and
              intuitive to use.
            </p>
            <div
              id="worldmap"
              class="relative w-[522px] h-[342px] mt-[-230px] md:mt-[-230px] md:ml-[200px] -mb-3 md:-mb-6 -z-10"
            >
              <div
                class="absolute top-0 right-0 bottom-0 left-0 bg-gradient-to-br from-brand-sand-light from-30% via-60% via-transparent"
              >
              </div>
              <img src="/worldmap.svg" alt="Uruguay in the world map" />
            </div>
          </div>
          <Contact />
        </div>
      </div>
    </div>
  </body>
</html>
